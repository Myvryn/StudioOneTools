<Window x:Class="StudioOneTools.App.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Studio One Tools"
        Height="440"
        Width="860"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ToolCardStyle" TargetType="Button">
            <Setter Property="Width" Value="180" />
            <Setter Property="Height" Value="180" />
            <Setter Property="Margin" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="#FFD0D0D0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#FFF0F6FF" />
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#FF0078D4" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#FFDCE7F8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#FFF4F4F4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="32,28,32,16">
                <TextBlock FontSize="24"
                           FontWeight="SemiBold"
                           Text="Studio One Tools" />
                <TextBlock Margin="0,6,0,0"
                           FontSize="13"
                           Foreground="#FF666666"
                           Text="Select a tool to get started." />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <WrapPanel Margin="20,0,20,28"
                       HorizontalAlignment="Center"
                       Orientation="Horizontal">

                <Button Style="{StaticResource ToolCardStyle}"
                        Click="SongArchiverCard_OnClick">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="44"
                                   Foreground="#FF0078D4"
                                   HorizontalAlignment="Center"
                                   Text="&#xE8B7;" />
                        <TextBlock Margin="0,12,0,0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Text="Song Archiver" />
                        <TextBlock Margin="10,5,10,0"
                                   FontSize="11"
                                   Foreground="#FF888888"
                                   HorizontalAlignment="Center"
                                   MaxWidth="160"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="Archive song folders and manage media files." />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolCardStyle}"
                        Click="SweeperCard_OnClick">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="44"
                                   Foreground="#FFD45B07"
                                   HorizontalAlignment="Center"
                                   Text="&#xE74D;" />
                        <TextBlock Margin="0,12,0,0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Text="Folder Sweeper" />
                        <TextBlock Margin="10,5,10,0"
                                   FontSize="11"
                                   Foreground="#FF888888"
                                   HorizontalAlignment="Center"
                                   MaxWidth="160"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="Find and remove old or incomplete song folders." />
                    </StackPanel>
                </Button>

            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Window>
