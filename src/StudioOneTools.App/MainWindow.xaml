<Window x:Class="StudioOneTools.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:StudioOneTools.App.Converters"
        mc:Ignorable="d"
        Title="Studio One Tools - Archiver"
        Height="780"
        Width="1180"
        MinHeight="720"
        MinWidth="1040"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:ProgressToBrushConverter x:Key="ProgressToBrush" />
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0"
              Grid.ColumnSpan="2"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Text="Studio One Song Archiver" />

            <Button Grid.Column="1"
                    Padding="16,6"
                    VerticalAlignment="Top"
                    Click="SettingsButton_OnClick"
                    Content="⚙ Settings"
                    ToolTip="Configure default folders" />
        </Grid>

        <Grid Grid.Row="1"
              Grid.ColumnSpan="2"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       Text="Song folder" />

            <TextBox x:Name="SourceFolderPathTextBox"
                     Grid.Column="1"
                     MinWidth="520"
                     Padding="8,6"
                     Text="{Binding SourceFolderPath, UpdateSourceTrigger=PropertyChanged}"
                     TextChanged="SourceFolderPathTextBox_OnTextChanged" />

            <Button Grid.Column="2"
                    Margin="12,0,0,0"
                    Padding="16,6"
                    Click="BrowseSongFolderButton_OnClick"
                    Content="Browse..." />
        </Grid>

        <Grid Grid.Row="2"
              Grid.ColumnSpan="2"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       Text="Archive file" />

            <TextBox Grid.Column="1"
                     MinWidth="520"
                     Padding="8,6"
                     Text="{Binding ArchiveFilePath, UpdateSourceTrigger=PropertyChanged}" />

            <Button Grid.Column="2"
                    Margin="12,0,0,0"
                    Padding="16,6"
                    Click="BrowseArchiveFileButton_OnClick"
                    Content="Save As..." />
        </Grid>

        <StackPanel Grid.Row="3"
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,12"
                    Orientation="Horizontal">
            <CheckBox Margin="0,0,20,0"
                      IsChecked="{Binding RetainMixdownFiles}"
                      Content="Retain Mixdown files" />
            <CheckBox Margin="0,0,20,0"
                      IsChecked="{Binding RetainMasterFiles}"
                      Content="Retain Master files" />
            <Button Padding="16,6"
                    Margin="0,0,12,0"
                    Click="ArchiveButton_OnClick"
                    Content="Create Archive"
                    IsEnabled="{Binding CanArchive}" />
        </StackPanel>

        <Grid Grid.Row="4"
              Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,12"
                    Padding="12"
                    BorderBrush="#FFCCCCCC"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock FontWeight="SemiBold" Text="{Binding SongName}" />
                        <TextBlock Margin="0,6,0,0" Text="{Binding SongFilePath}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,6,0,0" Text="{Binding IssuesSummary}" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="24,0,16,0">
                        <TextBlock FontWeight="SemiBold" Text="Used WAVs" />
                        <TextBlock FontSize="22" Text="{Binding UsedWaveFileCount}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,24,0">
                        <TextBlock FontWeight="SemiBold" Text="Unused WAVs" />
                        <TextBlock FontSize="22" Text="{Binding UnusedWaveFileCount}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3"
                                VerticalAlignment="Center">
                        <TextBlock FontWeight="SemiBold" Text="Preview" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="11"
                                   Foreground="#FF666666"
                                   Text="{Binding PreviewLabel}"
                                   TextWrapping="Wrap"
                                   MaxWidth="180" />
                        <Button Margin="0,8,0,0"
                                Padding="12,6"
                                IsEnabled="{Binding HasPreviewFile}"
                                Content="{Binding PlayButtonContent}"
                                Click="PlayPreviewButton_OnClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      ItemsSource="{Binding MediaFiles}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="Black" />
                        <Setter Property="Background">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource ProgressToBrush}">
                                    <Binding RelativeSource="{RelativeSource Self}" Path="IsSelected" />
                                    <Binding Path="PlaybackProgress" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="Foreground" Value="Black" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Foreground" Value="Black" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Play" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="▶"
                                        Padding="8,4"
                                        FontSize="12"
                                        Click="PlayMediaFile_OnClick"
                                        ToolTip="Play audio file"
                                        IsEnabled="{Binding IsWaveFile}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Binding="{Binding FileName}" Header="File" Width="220" />
                    <DataGridTextColumn Binding="{Binding RelativePath}" Header="Relative Path" Width="*" />
                    <DataGridCheckBoxColumn Binding="{Binding IsUsed}" Header="Used" Width="80" />
                    <DataGridCheckBoxColumn Binding="{Binding ExistsOnDisk}" Header="Exists" Width="80" />
                    <DataGridTextColumn Binding="{Binding UseCount}" Header="Use Count" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Row="5"
                Grid.ColumnSpan="2"
                Margin="0,12,0,0"
                Padding="10"
                Background="#FFF4F4F4"
                BorderBrush="#FFD0D0D0"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
        </Border>

        <Grid Grid.Row="0"
              Grid.RowSpan="6"
              Grid.Column="0"
              Grid.ColumnSpan="2"
              Background="#CC202020"
              Visibility="{Binding IsArchiving, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="300"
                             Height="6" />
                <TextBlock Margin="0,16,0,0"
                           Foreground="White"
                           FontSize="15"
                           HorizontalAlignment="Center"
                           Text="Creating archive, please wait…" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
